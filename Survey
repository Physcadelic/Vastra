  const inO=sel.filter(s=>s.channel==='Insta DM').length;
  const waO=sel.filter(s=>s.channel==='WhatsApp').length;
  const bo=sel.filter(s=>s.channel==='Both').length;
  const tot=sel.length||1;
  const chanSegs=[{l:'Insta DM',v:inO,c:'#7a5ca8'},{l:'WhatsApp',v:waO,c:'#4a9460'},{l:'Both',v:bo,c:'#3a5ca8'}];
  document.getElementById('cgrid1').innerHTML=`
    <div class="ccard"><div class="cc-title">Fabric Distribution</div><div class="cc-sub">Designs per fabric in selection</div>${barChart(fabData,l=>FC[l]||'#c8913a')}</div>
    <div class="ccard">
      <div class="cc-title">Channel Fit</div><div class="cc-sub">Where each design performs best</div>
      <div style="display:flex;align-items:center;gap:16px;justify-content:center">
        ${donut(chanSegs,tot)}
        <div style="display:flex;flex-direction:column;gap:8px">
          ${chanSegs.map(s=>`<div style="display:flex;align-items:center;gap:6px"><div style="width:9px;height:9px;border-radius:3px;background:${s.c};flex-shrink:0"></div><div style="font-size:12px;color:var(--ink2);flex:1">${s.l}</div><div style="font-size:13px;font-weight:700;color:var(--ink)">${s.v}</div></div>`).join('')}
        </div>
      </div>
    </div>`;
}

