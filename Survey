function toggleGroup(k){
  const el=document.getElementById('fitems-'+k);
  const arr=document.getElementById('farr-'+k);
  const open=el.style.display!=='none';
  el.style.display=open?'none':'block';
  arr.classList.toggle('open',!open);
}

function chipClick(el,fab){
  if(chipActive===fab){
    chipActive=null;el.style.background='';el.style.color='';el.style.borderColor='';
    DATA.forEach(s=>{const e=document.getElementById('si-'+s.id);if(e)e.classList.remove('hidden');});
  } else {
    chipActive=fab;
    document.querySelectorAll('.fchip').forEach(c=>{c.style.background='';c.style.color='';c.style.borderColor='';});
    el.style.background=FC[fab];el.style.color='#fff';el.style.borderColor=FC[fab];
    DATA.forEach(s=>{const e=document.getElementById('si-'+s.id);if(e)e.classList.toggle('hidden',s.fabric!==fab);});
  }
}

