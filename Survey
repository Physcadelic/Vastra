<!DOCTYPE html>


<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Saree Brand Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#faf7f2;--bg2:#f2ede4;--white:#fff;
  --ink:#1c1814;--ink2:#4a3f35;--ink3:#9a8f82;--border:#e2d9ce;
  --gold:#c8913a;--gold-lt:#f0d9a8;
  --rose:#c95c5c;--teal:#3a8a82;--green:#4a9460;--purple:#7a5ca8;--blue:#3a5ca8;
  --shadow:0 2px 16px rgba(0,0,0,.07);--shadow-lg:0 8px 40px rgba(0,0,0,.12);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;}

/* NAV */
nav{background:var(–ink);height:62px;padding:0 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:300;border-bottom:2px solid var(–gold);}
.nav-brand{font-family:‘Cormorant Garamond’,serif;font-size:20px;font-weight:700;color:var(–gold-lt);letter-spacing:.5px;white-space:nowrap;}
.nav-brand em{color:var(–gold);font-style:normal;}
.nav-tabs{display:flex;gap:2px;}
.nav-tab{padding:7px 14px;font-size:12px;font-weight:600;color:#aaa;background:transparent;border:none;cursor:pointer;border-radius:6px;transition:all .2s;font-family:‘DM Sans’,sans-serif;white-space:nowrap;}
.nav-tab:hover{color:#fff;background:rgba(255,255,255,.08);}
.nav-tab.active{background:var(–gold);color:var(–ink);}
.nav-right{display:flex;align-items:center;gap:10px;}
.sel-badge{background:rgba(200,145,58,.2);color:var(–gold-lt);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;white-space:nowrap;}
.sub-count-badge{background:rgba(74,148,96,.2);color:#7fcf9a;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;white-space:nowrap;}
.exp-btn{background:transparent;border:1px solid var(–gold);color:var(–gold);padding:6px 12px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;font-family:‘DM Sans’,sans-serif;transition:all .2s;}
.exp-btn:hover{background:var(–gold);color:var(–ink);}

/* LAYOUT */
.layout{display:grid;grid-template-columns:380px 1fr;min-height:calc(100vh - 62px);}

/* LEFT */
.catalogue{background:var(–white);border-right:1px solid var(–border);display:flex;flex-direction:column;max-height:calc(100vh - 62px);}
.cat-hdr{padding:14px 16px 10px;border-bottom:1px solid var(–border);background:var(–white);flex-shrink:0;}
.cat-hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.cat-title{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(–ink3);font-weight:600;}
.sel-btns{display:flex;gap:5px;}
.sel-btn{font-size:11px;padding:3px 9px;border-radius:12px;border:1px solid var(–border);background:transparent;color:var(–ink3);cursor:pointer;font-family:‘DM Sans’,sans-serif;transition:all .2s;}
.sel-btn:hover{border-color:var(–gold);color:var(–gold);}
.chip-row{display:flex;gap:4px;flex-wrap:wrap;}
.fchip{padding:3px 9px;border-radius:12px;font-size:10px;font-weight:600;border:1.5px solid var(–border);background:transparent;cursor:pointer;color:var(–ink3);transition:all .2s;font-family:‘DM Sans’,sans-serif;}
.fchip:hover{border-color:var(–gold);color:var(–gold);}

.cat-list-wrap{overflow-y:auto;flex:1;}
.fab-hdr{padding:10px 16px;background:var(–bg2);border-bottom:1px solid var(–border);display:flex;align-items:center;gap:8px;cursor:pointer;transition:background .15s;user-select:none;}
.fab-hdr:hover{background:#ede6d9;}
.fab-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.fab-name{font-family:‘Cormorant Garamond’,serif;font-size:14px;font-weight:700;color:var(–ink);}
.fab-meta{margin-left:auto;display:flex;align-items:center;gap:7px;}
.fab-cnt{font-size:10px;color:var(–ink3);}
.fab-sel{font-size:10px;font-weight:700;color:var(–gold);}
.fab-arrow{font-size:10px;color:var(–ink3);transition:transform .2s;}
.fab-arrow.open{transform:rotate(180deg);}

.saree-item{display:flex;align-items:flex-start;gap:9px;padding:8px 16px;border-bottom:1px solid #f5f0e8;cursor:pointer;transition:background .15s;}
.saree-item:hover{background:#fdf9f3;}
.saree-item.checked{background:#fef9ec;}
.saree-item.hidden{display:none;}
.cbox{width:15px;height:15px;border-radius:4px;border:2px solid var(–border);background:transparent;flex-shrink:0;margin-top:3px;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.saree-item.checked .cbox{background:var(–gold);border-color:var(–gold);}
.cbox-tick{display:none;color:#fff;font-size:8px;font-weight:900;}
.saree-item.checked .cbox-tick{display:block;}
.s-body{flex:1;min-width:0;}
.s-row1{display:flex;align-items:center;gap:6px;margin-bottom:2px;}
.s-no{font-size:10px;color:var(–ink3);font-weight:700;min-width:18px;}
.s-design{font-size:12px;font-weight:600;color:var(–ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;}
.s-row2{display:flex;gap:5px;align-items:center;flex-wrap:wrap;}
.s-price{font-size:11px;font-weight:700;color:var(–gold);}
.s-trend{font-size:9px;padding:2px 5px;border-radius:8px;font-weight:700;}
.t-top{background:rgba(74,148,96,.12);color:var(–green);}
.t-good{background:rgba(200,145,58,.12);color:var(–gold);}
.t-niche{background:rgba(201,92,92,.12);color:var(–rose);}
.s-chan{font-size:10px;color:var(–ink3);}
.s-row3{font-size:10px;color:var(–ink3);margin-top:1px;font-style:italic;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* SUBMIT BAR */
.submit-bar{padding:12px 16px;border-top:1px solid var(–border);background:var(–white);flex-shrink:0;}
.submit-btn{width:100%;padding:12px;background:var(–ink);color:var(–gold-lt);border:none;border-radius:10px;font-family:‘Cormorant Garamond’,serif;font-size:15px;font-weight:700;cursor:pointer;letter-spacing:.5px;transition:all .25s;display:flex;align-items:center;justify-content:center;gap:8px;opacity:.35;pointer-events:none;}
.submit-btn.active{opacity:1;pointer-events:all;}
.submit-btn.active:hover{background:var(–gold);color:var(–ink);transform:translateY(-1px);box-shadow:0 6px 20px rgba(200,145,58,.3);}
.s-count{background:rgba(255,255,255,.15);padding:2px 8px;border-radius:10px;font-size:11px;font-family:‘DM Sans’,sans-serif;font-weight:700;}

/* RIGHT PANEL */
.dashboard{overflow-y:auto;max-height:calc(100vh - 62px);padding:24px 28px;}
.dpanel{display:none;}
.dpanel.active{display:block;animation:fadeIn .3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* KPIs */
.kpi-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:11px;margin-bottom:18px;}
.kpi{background:var(–white);border-radius:11px;padding:14px;box-shadow:var(–shadow);border-top:3px solid transparent;transition:transform .2s;}
.kpi:hover{transform:translateY(-2px);}
.kpi.k1{border-color:var(–gold)}.kpi.k2{border-color:var(–teal)}.kpi.k3{border-color:var(–green)}.kpi.k4{border-color:var(–rose)}.kpi.k5{border-color:var(–purple)}
.kpi-val{font-family:‘Cormorant Garamond’,serif;font-size:28px;font-weight:700;color:var(–ink);line-height:1;}
.kpi-lbl{font-size:10px;color:var(–ink3);text-transform:uppercase;letter-spacing:1px;margin-top:4px;}

.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.ccard{background:var(–white);border-radius:12px;padding:18px;box-shadow:var(–shadow);}
.ccard.full{grid-column:span 2;}
.cc-title{font-family:‘Cormorant Garamond’,serif;font-size:15px;font-weight:700;color:var(–ink);margin-bottom:2px;}
.cc-sub{font-size:11px;color:var(–ink3);margin-bottom:12px;}

/* EMPTY STATE */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 20px;color:var(–ink3);text-align:center;}
.empty-icon{font-size:52px;margin-bottom:16px;opacity:.4;}
.empty-title{font-family:‘Cormorant Garamond’,serif;font-size:22px;font-weight:700;color:var(–ink2);margin-bottom:8px;}
.empty-text{font-size:13px;line-height:1.6;}

/* SUBMISSIONS PANEL */
.subs-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.subs-title{font-family:‘Cormorant Garamond’,serif;font-size:24px;font-weight:700;}
.subs-meta{font-size:12px;color:var(–ink3);}
.clear-subs-btn{font-size:12px;padding:6px 14px;border-radius:8px;border:1px solid var(–border);background:transparent;color:var(–ink3);cursor:pointer;font-family:‘DM Sans’,sans-serif;transition:all .2s;}
.clear-subs-btn:hover{border-color:var(–rose);color:var(–rose);}

/* SUBMISSION CARD */
.sub-card{background:var(–white);border-radius:14px;box-shadow:var(–shadow);margin-bottom:20px;overflow:hidden;border:1px solid var(–border);}
.sub-card-hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid var(–border);background:var(–bg2);}
.sub-card-left{display:flex;align-items:center;gap:12px;}
.sub-num{width:32px;height:32px;border-radius:50%;background:var(–gold);color:var(–ink);font-family:‘Cormorant Garamond’,serif;font-size:15px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sub-info-title{font-family:‘Cormorant Garamond’,serif;font-size:15px;font-weight:700;color:var(–ink);}
.sub-info-meta{font-size:11px;color:var(–ink3);margin-top:1px;}
.sub-pills{display:flex;gap:6px;flex-wrap:wrap;}
.sub-pill{font-size:10px;padding:3px 9px;border-radius:10px;font-weight:700;}
.pill-gold{background:rgba(200,145,58,.12);color:var(–gold);}
.pill-green{background:rgba(74,148,96,.12);color:var(–green);}
.pill-blue{background:rgba(58,92,168,.12);color:var(–blue);}
.pill-rose{background:rgba(201,92,92,.12);color:var(–rose);}

.sub-charts{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:0;border-top:1px solid var(–border);}
.sub-chart-cell{padding:16px 18px;border-right:1px solid var(–border);}
.sub-chart-cell:last-child{border-right:none;}
.scc-title{font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(–ink3);font-weight:700;margin-bottom:12px;}

/* MINI BAR CHART */
.mini-bar-chart{display:flex;flex-direction:column;gap:5px;}
.mb-row{display:flex;align-items:center;gap:6px;}
.mb-lbl{font-size:9px;color:var(–ink2);width:72px;flex-shrink:0;text-align:right;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.mb-track{flex:1;height:14px;background:var(–bg2);border-radius:3px;overflow:hidden;}
.mb-fill{height:100%;border-radius:3px;transition:width .7s cubic-bezier(.4,0,.2,1);min-width:14px;display:flex;align-items:center;justify-content:flex-end;padding-right:4px;}
.mb-fill span{font-size:8px;font-weight:700;color:rgba(255,255,255,.9);}

/* MINI DONUT */
.mini-donut-wrap{display:flex;flex-direction:column;align-items:center;gap:8px;}
.mini-legend{display:flex;flex-direction:column;gap:4px;width:100%;}
.ml-row{display:flex;align-items:center;gap:5px;}
.ml-dot{width:7px;height:7px;border-radius:2px;flex-shrink:0;}
.ml-lbl{font-size:9px;color:var(–ink2);flex:1;}
.ml-val{font-size:10px;font-weight:700;color:var(–ink);}

/* PRICE MINI */
.price-mini{display:flex;flex-direction:column;gap:4px;}
.pm-row{display:flex;align-items:center;justify-content:space-between;padding:4px 8px;border-radius:6px;background:var(–bg2);}
.pm-lbl{font-size:9px;color:var(–ink2);font-weight:500;}
.pm-val{font-size:10px;font-weight:700;color:var(–gold);}

/* ITEMS LIST */
.sub-items-preview{padding:12px 20px;border-top:1px solid var(–border);display:flex;flex-wrap:wrap;gap:5px;}
.sub-item-tag{font-size:10px;background:var(–bg2);color:var(–ink2);padding:3px 9px;border-radius:8px;font-weight:500;}
.sub-toggle{font-size:11px;color:var(–teal);cursor:pointer;background:none;border:none;font-family:‘DM Sans’,sans-serif;font-weight:600;padding:0;}
.sub-toggle:hover{text-decoration:underline;}

/* COMPARE ROW */
.compare-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:14px;}
.compare-cell{background:var(–white);border-radius:10px;padding:14px;box-shadow:var(–shadow);text-align:center;}
.cc-num{font-size:11px;font-weight:700;color:var(–gold);margin-bottom:4px;}
.cc-val{font-family:‘Cormorant Garamond’,serif;font-size:22px;font-weight:700;color:var(–ink);}
.cc-lbl{font-size:10px;color:var(–ink3);margin-top:2px;}

/* TABLE */
.tbl-wrap{background:var(–white);border-radius:12px;box-shadow:var(–shadow);overflow:hidden;}
.ctable{width:100%;border-collapse:collapse;}
.ctable th{padding:10px 12px;font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(–ink3);font-weight:700;background:var(–bg2);border-bottom:1px solid var(–border);text-align:left;}
.ctable td{padding:9px 12px;font-size:12px;border-bottom:1px solid var(–bg);color:var(–ink2);vertical-align:middle;}
.ctable tr:hover td{background:var(–bg);}
.ctable tr:last-child td{border-bottom:none;}
.badge{display:inline-block;padding:2px 7px;border-radius:10px;font-size:10px;font-weight:700;}
.b-top{background:#d1fae5;color:#065f46}.b-good{background:#fef3c7;color:#92400e}.b-niche{background:#fee2e2;color:#991b1b}
.b-insta{background:#ede9fe;color:#5b21b6}.b-wa{background:#dcfce7;color:#166534}.b-both{background:#e0f2fe;color:#075985}

/* FILTER */
.fp-grid{display:grid;grid-template-columns:240px 1fr;gap:16px;}
.fp-sb{background:var(–white);border-radius:12px;padding:18px;box-shadow:var(–shadow);height:fit-content;position:sticky;top:0;}
.fp-stitle{font-family:‘Cormorant Garamond’,serif;font-size:16px;font-weight:700;margin-bottom:14px;}
.fp-grp{margin-bottom:14px;}
.fp-lbl{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(–ink3);font-weight:700;margin-bottom:6px;}
.fp-opts{display:flex;flex-direction:column;gap:2px;}
.fp-opt{display:flex;align-items:center;gap:6px;padding:5px 6px;border-radius:6px;cursor:pointer;transition:background .15s;}
.fp-opt:hover{background:var(–bg);}
.fp-opt input[type=checkbox]{accent-color:var(–gold);width:13px;height:13px;cursor:pointer;}
.fp-opt-lbl{font-size:11px;color:var(–ink2);flex:1;}
.fp-opt-cnt{font-size:9px;background:var(–bg2);color:var(–ink3);padding:1px 5px;border-radius:8px;font-weight:600;}
.fp-clear{width:100%;padding:8px;background:transparent;color:var(–ink3);border:1px solid var(–border);border-radius:8px;font-family:‘DM Sans’,sans-serif;font-size:12px;cursor:pointer;margin-top:4px;transition:all .2s;}
.fp-clear:hover{border-color:var(–ink2);color:var(–ink2);}

/* EXPORT */
.exp-wrap{max-width:660px;}
.exp-title{font-family:‘Cormorant Garamond’,serif;font-size:24px;font-weight:700;margin-bottom:4px;}
.exp-sub{font-size:12px;color:var(–ink3);margin-bottom:22px;}
.exp-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:22px;}
.exp-card{background:var(–white);border-radius:12px;padding:20px;box-shadow:var(–shadow);cursor:pointer;transition:all .2s;border:2px solid transparent;display:flex;gap:12px;align-items:flex-start;}
.exp-card:hover{border-color:var(–gold);transform:translateY(-2px);box-shadow:var(–shadow-lg);}
.exp-icon{font-size:28px;}
.exp-info h3{font-family:‘Cormorant Garamond’,serif;font-size:15px;font-weight:700;margin-bottom:3px;}
.exp-info p{font-size:11px;color:var(–ink3);line-height:1.5;}
.exp-tag{display:inline-block;margin-top:6px;padding:2px 7px;background:var(–bg2);border-radius:8px;font-size:9px;font-weight:700;color:var(–ink2);letter-spacing:1px;text-transform:uppercase;}
.exp-sum{background:var(–white);border-radius:12px;padding:22px;box-shadow:var(–shadow);}
.exp-sum-title{font-family:‘Cormorant Garamond’,serif;font-size:16px;font-weight:700;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(–border);}
.exp-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(–bg2);}
.exp-key{font-size:12px;color:var(–ink3);}
.exp-val{font-size:12px;font-weight:700;color:var(–ink);}
.dl-btn{width:100%;padding:12px;background:var(–ink);color:#fff;border:none;border-radius:9px;font-family:‘Cormorant Garamond’,serif;font-size:14px;font-weight:700;cursor:pointer;margin-top:16px;transition:all .2s;letter-spacing:.5px;}
.dl-btn:hover{background:var(–gold);color:var(–ink);}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(28,24,20,.72);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(4px);}
.modal-overlay.show{opacity:1;pointer-events:all;}
.modal-card{background:var(–white);border-radius:22px;padding:44px 40px;max-width:460px;width:90%;text-align:center;box-shadow:0 24px 80px rgba(0,0,0,.2);transform:translateY(24px) scale(.96);transition:all .35s cubic-bezier(.34,1.56,.64,1);position:relative;overflow:hidden;}
.modal-card::before{content:’’;position:absolute;top:-60px;right:-60px;width:160px;height:160px;border-radius:50%;background:var(–gold);opacity:.06;}
.modal-card::after{content:’’;position:absolute;bottom:-70px;left:-40px;width:200px;height:200px;border-radius:50%;background:var(–teal);opacity:.05;}
.modal-overlay.show .modal-card{transform:translateY(0) scale(1);}
.modal-icon{font-size:58px;margin-bottom:16px;display:block;animation:bounce .6s .2s both;}
@keyframes bounce{0%{transform:scale(0)}60%{transform:scale(1.15)}100%{transform:scale(1)}}
.modal-title{font-family:‘Cormorant Garamond’,serif;font-size:28px;font-weight:700;color:var(–ink);margin-bottom:8px;}
.modal-sub{font-size:13px;color:var(–ink3);line-height:1.6;margin-bottom:20px;}
.modal-summary{background:var(–bg2);border-radius:11px;padding:14px 18px;margin-bottom:20px;text-align:left;}
.ms-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(–border);}
.ms-row:last-child{border-bottom:none;}
.ms-key{font-size:12px;color:var(–ink3);}
.ms-val{font-size:12px;font-weight:700;color:var(–ink);}
.modal-hint{font-size:12px;color:var(–teal);font-weight:600;margin-bottom:14px;}
.modal-close{width:100%;padding:12px;background:var(–ink);color:var(–gold-lt);border:none;border-radius:9px;font-family:‘Cormorant Garamond’,serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;letter-spacing:.5px;}
.modal-close:hover{background:var(–gold);color:var(–ink);}
.modal-close2{width:100%;padding:9px;background:transparent;color:var(–ink3);border:1px solid var(–border);border-radius:9px;font-family:‘DM Sans’,sans-serif;font-size:12px;cursor:pointer;margin-top:7px;transition:all .2s;}
.modal-close2:hover{border-color:var(–ink2);color:var(–ink2);}
.confetti-dot{position:absolute;width:8px;height:8px;border-radius:50%;animation:confettifall 1.2s ease-out forwards;}
@keyframes confettifall{0%{transform:translateY(-10px) rotate(0deg);opacity:1}100%{transform:translateY(320px) rotate(720deg);opacity:0}}
</style>

</head>
<body>

<nav>
  <div class="nav-brand">Drape<em>Studio</em> · Catalogue</div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="goTab('overview',this)">📊 Overview</button>
    <button class="nav-tab" onclick="goTab('submissions',this)">📈 Submissions</button>
    <button class="nav-tab" onclick="goTab('catalogue',this)">📋 Catalogue</button>
    <button class="nav-tab" onclick="goTab('filter',this)">🔍 Filter</button>
    <button class="nav-tab" onclick="goTab('export',this)">📤 Export</button>
  </div>
  <div class="nav-right">
    <span class="sel-badge" id="sel-badge">0 selected</span>
    <span class="sub-count-badge" id="sub-count-badge">0 submissions</span>
    <button class="exp-btn" onclick="exportCSV()">⬇ CSV</button>
  </div>
</nav>

<div class="layout">

  <!-- LEFT: CATALOGUE -->

  <div class="catalogue">
    <div class="cat-hdr">
      <div class="cat-hdr-top">
        <span class="cat-title">42 Designs</span>
        <div class="sel-btns">
          <button class="sel-btn" onclick="selectAll()">All</button>
          <button class="sel-btn" onclick="clearAll()">Clear</button>
        </div>
      </div>
