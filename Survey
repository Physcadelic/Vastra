function barChart(data,colorFn){
  const max=Math.max(...data.map(d=>d.v),1);
  return `<div class="bar-chart" style="display:flex;flex-direction:column;gap:8px">${data.map(d=>`
    <div style="display:flex;align-items:center;gap:9px">
      <div style="font-size:11px;color:var(--ink2);width:105px;flex-shrink:0;text-align:right;font-weight:500">${d.l}</div>
      <div style="flex:1;height:22px;background:var(--bg2);border-radius:5px;overflow:hidden">
        <div style="width:${(d.v/max*100)}%;height:100%;border-radius:5px;background:${colorFn(d.l)};display:flex;align-items:center;padding:0 7px;font-size:11px;font-weight:700;color:#fff;min-width:22px;transition:width .7s">${d.v||''}</div>
      </div>
      <div style="font-size:11px;color:var(--ink3);width:20px;text-align:right">${d.v}</div>
    </div>`).join('')}</div>`;
}

function donut(segs,tot){
  const r=52,cx=62,cy=62,sw=18,circ=2*Math.PI*r;
  let off=0,paths='';
  segs.forEach(s=>{
    const d=(tot>0?s.v/tot:0)*circ;
    paths+=`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${s.c}" stroke-width="${sw}" stroke-dasharray="${d} ${circ}" stroke-dashoffset="${-off}" transform="rotate(-90 ${cx} ${cy})" style="transition:stroke-dasharray .7s"/>`;
    off+=d;
  });
  return `<svg width="124" height="124" viewBox="0 0 124 124">
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#f2ede4" stroke-width="${sw}"/>
    ${paths}
    <text x="${cx}" y="${cy-3}" text-anchor="middle" font-size="20" font-weight="700" fill="#1c1814" font-family="Cormorant Garamond,serif">${tot}</text>
    <text x="${cx}" y="${cy+13}" text-anchor="middle" font-size="9" fill="#9a8f82" font-family="DM Sans,sans-serif">total</text>
  </svg>`;
}

function renderGrid1(sel){
