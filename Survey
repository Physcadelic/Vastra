// ======================== SUBMISSIONS ========================
function submitSelection(){
  if(!checked.size) return;
  const sel=DATA.filter(s=>checked.has(s.id));
  const ts=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  const avg=Math.round(sel.reduce((a,s)=>a+s.price,0)/sel.length);
  const top=sel.filter(s=>s.trend==='Top Trend').length;
  const insta=sel.filter(s=>s.channel==='Insta DM'||s.channel==='Both').length;
  const wa=sel.filter(s=>s.channel==='WhatsApp'||s.channel==='Both').length;
  const fc={};sel.forEach(s=>fc[s.fabric]=(fc[s.fabric]||0)+1);
  const topFab=Object.entries(fc).sort((a,b)=>b[1]-a[1])[0];

  // Store submission
  submissions.push({
    id:submissions.length+1,
    ts,
    items:[...sel],
    avg,top,insta,wa,fc,
    topFab:topFab?topFab[0]:'-'
  });

  // Update sub count badge
  document.getElementById('sub-count-badge').textContent=`${submissions.length} submission${submissions.length!==1?'s':''}`;
  document.getElementById('ex-subs').textContent=submissions.length;

  // Show modal
  document.getElementById('modal-summary').innerHTML=`
    <div class="ms-row"><span class="ms-key">Submission #</span><span class="ms-val">${submissions.length}</span></div>
    <div class="ms-row"><span class="ms-key">Total Designs</span><span class="ms-val">${sel.length}</span></div>
    <div class="ms-row"><span class="ms-key">Avg Price</span><span class="ms-val">₹${avg.toLocaleString()}</span></div>
    <div class="ms-row"><span class="ms-key">Top Trend Items</span><span class="ms-val">${top}</span></div>
    <div class="ms-row"><span class="ms-key">Insta DM Fit</span><span class="ms-val">${insta}</span></div>
    <div class="ms-row"><span class="ms-key">WhatsApp Fit</span><span class="ms-val">${wa}</span></div>
    <div class="ms-row"><span class="ms-key">Top Fabric</span><span class="ms-val">${topFab?topFab[0]:'-'}</span></div>`;

  document.getElementById('modal-overlay').classList.add('show');
  spawnConfetti();
  renderSubmissionsPanel();
}

function renderSubmissionsPanel(){
  const list=document.getElementById('subs-list');
  document.getElementById('subs-meta').textContent=`${submissions.length} submission${submissions.length!==1?'s':(', ')}. Charts update with each response.`;

  if(!submissions.length){
    list.innerHTML=`<div class="empty-state"><div class="empty-icon">📊</div><div class="empty-title">No Submissions Yet</div><div class="empty-text">Select designs from the left panel and click<br><strong>Submit Selection</strong> to see charts here.</div></div>`;
    return;
  }

  list.innerHTML='';

  // Overall comparison if > 1 submission
  if(submissions.length>1){
    const compDiv=document.createElement('div');
    compDiv.innerHTML=`
      <div style="font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:700;margin-bottom:10px;color:var(--ink)">📊 All Submissions Comparison</div>
      <div class="compare-row">
        ${submissions.map(sub=>`
          <div class="compare-cell">
            <div class="cc-num">Sub #${sub.id}</div>
            <div class="cc-val">${sub.items.length}</div>
            <div class="cc-lbl">designs · ₹${sub.avg.toLocaleString()} avg</div>
            <div style="margin-top:6px;font-size:10px;color:var(--green);font-weight:700">${sub.top} Top Trend</div>
          </div>`).join('')}
      </div>`;
    list.appendChild(compDiv);
  }

  // Individual submission cards (most recent first)
  [...submissions].reverse().forEach(sub=>{
    const card=document.createElement('div');
    card.className='sub-card';

    const fabs=["Organza","Georgette","Cotton","Linen Cotton","Crepe","Cotton Silk"];
    const fabData=fabs.map(f=>({l:f,v:sub.items.filter(s=>s.fabric===f).length})).filter(d=>d.v>0);
    const trendData=[
      {l:"Top Trend",v:sub.items.filter(s=>s.trend==='Top Trend').length,c:'#4a9460'},
      {l:"Good",v:sub.items.filter(s=>s.trend==='Good').length,c:'#c8913a'},
      {l:"Niche",v:sub.items.filter(s=>s.trend==='Niche').length,c:'#c95c5c'},
    ].filter(d=>d.v>0);
    const inO=sub.items.filter(s=>s.channel==='Insta DM').length;
    const waO=sub.items.filter(s=>s.channel==='WhatsApp').length;
    const boO=sub.items.filter(s=>s.channel==='Both').length;
    const chanSegs=[{l:'Insta DM',v:inO,c:'#7a5ca8'},{l:'WhatsApp',v:waO,c:'#4a9460'},{l:'Both',v:boO,c:'#3a5ca8'}].filter(d=>d.v>0);
    const brackets=[
      {l:"₹999",v:sub.items.filter(s=>s.price===999).length},
      {l:"₹1,099",v:sub.items.filter(s=>s.price===1099).length},
      {l:"₹1,149",v:sub.items.filter(s=>s.price===1149).length},
      {l:"₹1,199",v:sub.items.filter(s=>s.price===1199).length},
      {l:"₹1,249",v:sub.items.filter(s=>s.price===1249).length},
      {l:"₹1,299",v:sub.items.filter(s=>s.price===1299).length},
      {l:"₹1,349+",v:sub.items.filter(s=>s.price>=1349).length},
    ].filter(d=>d.v>0);

    const maxFab=Math.max(...fabData.map(d=>d.v),1);
    const maxTrend=Math.max(...trendData.map(d=>d.v),1);
    const maxBracket=Math.max(...brackets.map(d=>d.v),1);
    const donutTot=sub.items.length||1;

    card.innerHTML=`
      <div class="sub-card-hdr">
        <div class="sub-card-left">
          <div class="sub-num">${sub.id}</div>
          <div>
            <div class="sub-info-title">Submission #${sub.id} · ${sub.ts}</div>
            <div class="sub-info-meta">${sub.items.length} designs selected · ₹${sub.avg.toLocaleString()} avg price</div>
          </div>
        </div>
        <div class="sub-pills">
          <span class="sub-pill pill-green">${sub.top} Top Trend</span>
          <span class="sub-pill pill-blue">${sub.insta} Insta Fit</span>
          <span class="sub-pill pill-gold">${sub.topFab} Most</span>
          <span class="sub-pill pill-rose">₹${sub.avg.toLocaleString()} avg</span>
        </div>
      </div>

      <div class="sub-charts">
        <!-- Chart 1: Fabric -->
        <div class="sub-chart-cell">
          <div class="scc-title">Fabric Mix</div>
          <div class="mini-bar-chart">
            ${fabData.map(d=>`
              <div class="mb-row">
                <div class="mb-lbl" title="${d.l}">${d.l}</div>
                <div class="mb-track"><div class="mb-fill" style="width:${(d.v/maxFab*100)}%;background:${FC[d.l]}"><span>${d.v}</span></div></div>
              </div>`).join('')}
          </div>
        </div>

        <!-- Chart 2: Trend -->
        <div class="sub-chart-cell">
          <div class="scc-title">Trend Score</div>
          <div class="mini-bar-chart">
            ${trendData.map(d=>`
              <div class="mb-row">
                <div class="mb-lbl">${d.l}</div>
                <div class="mb-track"><div class="mb-fill" style="width:${(d.v/maxTrend*100)}%;background:${d.c}"><span>${d.v}</span></div></div>
              </div>`).join('')}
          </div>
        </div>

        <!-- Chart 3: Channel Donut -->
        <div class="sub-chart-cell">
          <div class="scc-title">Channel Fit</div>
          <div class="mini-donut-wrap">
            ${miniDonut(chanSegs,donutTot)}
            <div class="mini-legend">
              ${chanSegs.map(s=>`<div class="ml-row"><div class="ml-dot" style="background:${s.c}"></div><div class="ml-lbl">${s.l}</div><div class="ml-val">${s.v}</div></div>`).join('')}
            </div>
          </div>
        </div>

        <!-- Chart 4: Price -->
        <div class="sub-chart-cell">
          <div class="scc-title">Price Points</div>
          <div class="mini-bar-chart">
            ${brackets.map(d=>`
              <div class="mb-row">
                <div class="mb-lbl">${d.l}</div>
                <div class="mb-track"><div class="mb-fill" style="width:${(d.v/maxBracket*100)}%;background:#3a5ca8"><span>${d.v}</span></div></div>
              </div>`).join('')}
          </div>
        </div>
      </div>

      <div class="sub-items-preview" id="sub-items-${sub.id}">
        ${sub.items.slice(0,8).map(s=>`<span class="sub-item-tag">#${s.id} ${s.design.substring(0,18)}…</span>`).join('')}
        ${sub.items.length>8?`<button class="sub-toggle" onclick="toggleSubItems(${sub.id},${sub.items.length})">+${sub.items.length-8} more</button>`:''}
      </div>`;

    list.appendChild(card);
  });
}

let expandedSubs={};
function toggleSubItems(subId,total){
  const sub=submissions.find(s=>s.id===subId);
  if(!sub) return;
  const div=document.getElementById('sub-items-'+subId);
  if(expandedSubs[subId]){
    expandedSubs[subId]=false;
    div.innerHTML=sub.items.slice(0,8).map(s=>`<span class="sub-item-tag">#${s.id} ${s.design.substring(0,18)}…</span>`).join('')+`<button class="sub-toggle" onclick="toggleSubItems(${subId},${total})">+${total-8} more</button>`;
  } else {
    expandedSubs[subId]=true;
    div.innerHTML=sub.items.map(s=>`<span class="sub-item-tag">#${s.id} ${s.design.substring(0,20)}…</span>`).join('')+`<button class="sub-toggle" onclick="toggleSubItems(${subId},${total})">Show less</button>`;
  }
}

function miniDonut(segs,tot){
  const r=28,cx=32,cy=32,sw=10,circ=2*Math.PI*r;
  let off=0,paths='';
  segs.forEach(s=>{
    const d=(tot>0?s.v/tot:0)*circ;
    paths+=`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${s.c}" stroke-width="${sw}" stroke-dasharray="${d} ${circ}" stroke-dashoffset="${-off}" transform="rotate(-90 ${cx} ${cy})"/>`;
    off+=d;
  });
  return `<svg width="64" height="64" viewBox="0 0 64 64">
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#f2ede4" stroke-width="${sw}"/>
    ${paths}
    <text x="${cx}" y="${cy+4}" text-anchor="middle" font-size="11" font-weight="700" fill="#1c1814" font-family="Cormorant Garamond,serif">${tot}</text>
  </svg>`;
}

function clearSubmissions(){
  if(!submissions.length) return;
  if(!confirm('Clear all submission history?')) return;
  submissions=[];
  document.getElementById('sub-count-badge').textContent='0 submissions';
  document.getElementById('ex-subs').textContent='0';
  renderSubmissionsPanel();
}

// ======================== MODAL ========================
function closeModal(tab){
  document.getElementById('modal-overlay').classList.remove('show');
  if(tab){
    const btn=document.querySelector(`.nav-tab:nth-child(${tab==='submissions'?2:1})`);
    goTab(tab,btn);
  }
}

function spawnConfetti(){
  const colors=['#c8913a','#4a9460','#3a8a82','#7a5ca8','#c95c5c','#3a5ca8','#f0d9a8'];
  const card=document.getElementById('modal-card');
  for(let i=0;i<32;i++){
    const d=document.createElement('div');
    d.className='confetti-dot';
    d.style.cssText=`left:${5+Math.random()*90}%;top:${Math.random()*15}%;background:${colors[i%colors.length]};width:${5+Math.random()*8}px;height:${5+Math.random()*8}px;animation-delay:${Math.random()*.5}s;animation-duration:${.8+Math.random()*.9}s;border-radius:${Math.random()>.5?'50%':'3px'}`;
    card.appendChild(d);
    setTimeout(()=>d.remove(),1900);
  }
}

document.getElementById('modal-overlay').addEventListener('click',function(e){if(e.target===this)closeModal(null);});

// ======================== FILTER ========================
function buildFilterSidebar(){
  const fabs=[...new Set(DATA.map(s=>s.fabric))];
  document.getElementById('fp-fabric').innerHTML=fabs.map(f=>`<label class="fp-opt"><input type="checkbox" value="${f}" onchange="renderFP()"><span class="fp-opt-lbl">${f}</span><span class="fp-opt-cnt">${DATA.filter(s=>s.fabric===f).length}</span></label>`).join('');
  document.getElementById('fp-trend').innerHTML=['Top Trend','Good','Niche'].map(t=>`<label class="fp-opt"><input type="checkbox" value="${t}" onchange="renderFP()"><span class="fp-opt-lbl">${t}</span><span class="fp-opt-cnt">${DATA.filter(s=>s.trend===t).length}</span></label>`).join('');
  document.getElementById('fp-chan').innerHTML=['Insta DM','WhatsApp','Both'].map(c=>`<label class="fp-opt"><input type="checkbox" value="${c}" onchange="renderFP()"><span class="fp-opt-lbl">${c}</span><span class="fp-opt-cnt">${DATA.filter(s=>s.channel===c).length}</span></label>`).join('');
  const pr=[['Under ₹1,100',s=>s.price<1100],['₹1,100–₹1,249',s=>s.price>=1100&&s.price<=1249],['₹1,250–₹1,399',s=>s.price>=1250&&s.price<=1399],['₹1,400+',s=>s.price>=1400]];
  document.getElementById('fp-price').innerHTML=pr.map(([l,fn],i)=>`<label class="fp-opt"><input type="checkbox" value="${i}" onchange="renderFP()" data-pidx="${i}"><span class="fp-opt-lbl">${l}</span><span class="fp-opt-cnt">${DATA.filter(fn).length}</span></label>`).join('');
  renderFP();
}
const PBRACKETS=[s=>s.price<1100,s=>s.price>=1100&&s.price<=1249,s=>s.price>=1250&&s.price<=1399,s=>s.price>=1400];
function renderFP(){
  const fabC=[...document.querySelectorAll('#fp-fabric input:checked')].map(i=>i.value);
  const trC=[...document.querySelectorAll('#fp-trend input:checked')].map(i=>i.value);
  const chC=[...document.querySelectorAll('#fp-chan input:checked')].map(i=>i.value);
  const prC=[...document.querySelectorAll('#fp-price input:checked')].map(i=>parseInt(i.value));
  let f=DATA;
  if(fabC.length)f=f.filter(s=>fabC.includes(s.fabric));
  if(trC.length)f=f.filter(s=>trC.includes(s.trend));
  if(chC.length)f=f.filter(s=>chC.includes(s.channel));
  if(prC.length)f=f.filter(s=>prC.some(i=>PBRACKETS[i](s)));
  document.getElementById('fp-count').textContent=`Showing ${f.length} of 42`;
  const tb=t=>`<span class="badge ${t==='Top Trend'?'b-top':t==='Good'?'b-good':'b-niche'}">${t}</span>`;
  const cb=c=>`<span class="badge ${c==='Insta DM'?'b-insta':c==='WhatsApp'?'b-wa':'b-both'}">${c}</span>`;
  document.getElementById('fp-tbody').innerHTML=f.length
    ?f.map(s=>`<tr><td>${s.id}</td><td><strong style="color:${FC[s.fabric]}">${s.fabric}</strong></td><td>${s.design}</td><td><strong>₹${s.price.toLocaleString()}</strong></td><td>${tb(s.trend)}</td><td>${cb(s.channel)}</td><td style="font-size:11px;color:var(--ink3);max-width:140px">${s.note}</td></tr>`).join('')
    :`<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--ink3)">No items match.</td></tr>`;
}
function clearFilters(){document.querySelectorAll('#panel-filter input[type=checkbox]').forEach(i=>i.checked=false);renderFP();}

// ======================== EXPORT ========================
function updateExportPanel(sel){
  sel=sel||(checked.size>0?DATA.filter(s=>checked.has(s.id)):DATA);
  document.getElementById('ex-sel').textContent=checked.size;
  const avg=sel.length?Math.round(sel.reduce((a,s)=>a+s.price,0)/sel.length):0;
  document.getElementById('ex-avg').textContent=sel.length?`₹${avg.toLocaleString()}`:'—';
  const fc={};sel.forEach(s=>fc[s.fabric]=(fc[s.fabric]||0)+1);
  const tf=Object.entries(fc).sort((a,b)=>b[1]-a[1])[0];
  document.getElementById('ex-fab').textContent=tf?`${tf[0]} (${tf[1]})`:'—';
  document.getElementById('ex-insta').textContent=sel.filter(s=>s.channel==='Insta DM'||s.channel==='Both').length;
  document.getElementById('ex-wa').textContent=sel.filter(s=>s.channel==='WhatsApp'||s.channel==='Both').length;
}
function exportCSV(){
  const h=['S.No','Fabric','Design','Style','Colour','Price','Trend','Channel','Note'];
  const rows=DATA.map(s=>[s.id,`"${s.fabric}"`,`"${s.design}"`,`"${s.style}"`,`"${s.colour}"`,s.price,s.trend,s.channel,`"${s.note}"`]);
  dl('saree_catalogue.csv',[h,...rows].map(r=>r.join(',')).join('\n'),'text/csv');
}
function exportJSON(){dl('saree_catalogue.json',JSON.stringify(DATA,null,2),'application/json');}
function exportSelected(){
  if(!checked.size){alert('No items selected!');return;}
  const h=['S.No','Fabric','Design','Style','Colour','Price','Trend','Channel','Note'];
  const rows=DATA.filter(s=>checked.has(s.id)).map(s=>[s.id,`"${s.fabric}"`,`"${s.design}"`,`"${s.style}"`,`"${s.colour}"`,s.price,s.trend,s.channel,`"${s.note}"`]);
  dl('saree_selected.csv',[h,...rows].map(r=>r.join(',')).join('\n'),'text/csv');
}
function dl(name,content,type){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([content],{type}));a.download=name;a.click();}

// ======================== NAV ========================
function goTab(name,btn){
  document.querySelectorAll('.dpanel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  if(btn)btn.classList.add('active');
  else document.querySelectorAll('.nav-tab').forEach(t=>{if(t.textContent.toLowerCase().includes(name.slice(0,4)))t.classList.add('active');});
  if(name==='filter')buildFilterSidebar();
  if(name==='submissions')renderSubmissionsPanel();
  if(name==='export')updateExportPanel();
}

// ======================== INIT ========================
buildLeft();
refreshOverview();
renderSubmissionsPanel();
</script>

